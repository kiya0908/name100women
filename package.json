{
  "name": "name100women",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "typegen": "react-router typegen",
    "typecheck": "npm run typegen && tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply name100women --local",
    "db:migrate:remote": "wrangler d1 migrations apply name100women --remote",
    "db:seed:generate": "tsx scripts/generate-seed.ts",
    "db:seed:local": "wrangler d1 execute name100women --local --file=db/seed.sql",
    "db:seed:remote": "wrangler d1 execute name100women --remote --file=db/seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "rc",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^8.2.0",
    "zod": "^4.0.0",
    "isbot": "^5.1.40"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "latest",
    "@eslint/js": "^9.0.0",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "rc",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
